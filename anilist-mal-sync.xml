<?xml version="1.0"?>
<Container version="2">
  <Name>AniList-MAL-Sync</Name>
  <Repository>ghcr.io/tareku99/anilist-mal-sync:latest</Repository>
  <Registry>https://github.com/Tareku99/anilist-mal-sync/pkgs/container/anilist-mal-sync</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/Tareku99/anilist-mal-sync/issues</Support>
  <Project>https://github.com/Tareku99/anilist-mal-sync</Project>
  <Overview>Bidirectional sync service between AniList and MyAnimeList with OAuth authentication, conflict resolution, and Docker deployment.</Overview>
  <Description>Sync your anime lists between AniList and MyAnimeList with support for bidirectional sync, conflict resolution (latest update wins), one-way sync modes, automatic rate limiting and retry, plus a built-in web UI for monitoring and configuration management.</Description>
  <Category>Tools:Utilities</Category>
  <WebUI>http://[IP]:[PORT:23080]</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/Tareku99/anilist-mal-sync/main/anilist-mal-sync.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/Tareku99/anilist-mal-sync/main/src/anilist_mal_sync/assets/icon.png</Icon>
  <ExtraParams>--restart unless-stopped</ExtraParams>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Requires/>
  <Config Name="OAuth Port" Target="18080" Default="18080" Mode="tcp" Description="OAuth callback port for authentication" Type="Port" Display="always" Required="true" Mask="false">18080</Config>
  <Config Name="Web UI Port" Target="23080" Default="23080" Mode="tcp" Description="Web UI dashboard port" Type="Port" Display="always" Required="true" Mask="false">23080</Config>
  <Config Name="Data Directory" Target="/app/data" Default="/mnt/user/appdata/anilist-mal-sync" Mode="rw" Description="Contains config.yaml and tokens.json" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/anilist-mal-sync</Config>
  <Config Name="Timezone" Target="TZ" Default="America/Boise" Mode="" Description="Container timezone (e.g., America/New_York, Europe/London, Asia/Tokyo)" Type="Variable" Display="always" Required="false" Mask="false">America/Boise</Config>
</Container>
